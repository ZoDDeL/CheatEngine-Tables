[ENABLE]

aobscanmodule(teamscore,Project.dll,89 7C C2 20 8B CE 8B D7 E8 4A) // should be unique
alloc(newmem,$1000,teamscore)

label(code)
label(return)

newmem:
  mov esi,#0 // keeps score at 0

code:
  mov [rdx+rax*8+20],esi  // &lt;- write score value to address
  mov ecx,esi
  jmp return

teamscore:
  jmp newmem
  nop
return:
registersymbol(teamscore)

[DISABLE]

teamscore:
  db 89 7C C2 20 8B CE

unregistersymbol(teamscore)
